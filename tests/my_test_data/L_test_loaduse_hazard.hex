//# 初始化寄存器
//addi x1, x0, 1      # 设置基础地址 (假设内存 0x1 处可写)
//lui  x2, 0x12345       # x2 = 0x12345000
//addi x2, x2, 0x678     # x2 = 0x12345678 (测试数据)

//# --- 1. 测试 Store/Load Word (SW/LW) ---
//sw   x2, 0(x1)         # 将 0x12345678 存入 [x1]
//lw   x3, 0(x1)         # 紧接着加载回 x3 (触发 Load-Use 冒险)
//add  x4, x3, x0        # 再次触发 Load-Use 冒险 (x4 应等于 x3)

//# --- 2. 测试 Byte 存储与加载 (SB/LB/LBU) ---
//addi x5, x0, 0xEF      # 测试字节
//sb   x5, 4(x1)         # 存入 [x1+4]
//lb   x6, 4(x1)         # 符号扩展加载 (x6 应为 0xFFFFFFEF)
//lbu  x7, 4(x1)         # 无符号扩展加载 (x7 应为 0x000000EF)

//# --- 3. 测试 Halfword 存储与加载 (SH/LH/LHU) ---
//addi x8, x0, 0x7FF    # 测试半字
//sh   x8, 8(x1)         # 存入 [x1+8]
//lh   x9, 8(x1)         # 符号扩展加载 (x9 应为 0x00007BCD)
//lhu  x10, 8(x1)        # 无符号扩展加载 (x10 应为 0x00007BCD)

//# 死循环结束
