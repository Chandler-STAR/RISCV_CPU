// 1. 初始化寄存器 (I-Type)
00000093    // addi x1, x0, 0      (x1 = 0, 假设基准为0)
01400113    // addi x2, x0, 20     (x2 = 20, 测试数据)
01E00193    // addi x3, x0, 30     (x3 = 30, 另一个测试数据)

// 2. 存储指令测试 (S-Type)
0020A023    // sw x2, 0(x1)        (把 20 存入地址 0)
00309223    // sh x3, 4(x1)        (把 30 的低16位存入地址 4)
00208423    // sb x2, 8(x1)        (把 20 的低8位存入地址 8)

// 3. 负偏移量测试 (S-Type)
01000193    // addi x3, x0, 16     (x3 = 16)
FE21AC23    // sw x2, -4(x3)       (把 20 存入地址 12 [16-4])

// 4. 结束
00100073    // ebreak              (停止仿真)